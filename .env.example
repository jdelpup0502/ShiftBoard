# ── Local development ──────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
SESSION_PASSWORD="replace_with_a_random_string_at_least_32_characters_long"

# ── Production (Railway) ───────────────────────────────────────────
# DATABASE_URL="file:/data/prod.db"       ← absolute path to volume mount
# SESSION_PASSWORD="<openssl rand -base64 48>"

# ── First-time seed ────────────────────────────────────────────────
# Required only for the initial `npx prisma db seed` call.
# After the first deploy, remove or leave blank — the seed is idempotent
# (skips creation if any user already exists).
# SEED_ADMIN_USERNAME="admin"
# SEED_ADMIN_PASSWORD="choose-a-strong-password-min-12-chars-with-number"
